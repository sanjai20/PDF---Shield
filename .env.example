APP_NAME=PDF Shield API
APP_VERSION=1.1.0
DATABASE_URL=postgresql+psycopg2://pdfshield:pdfshield@db:5432/pdfshield
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MAX_UPLOAD_MB=25
MAX_PDF_PAGES=250
MAX_ZIP_ENTRIES=250
MAX_ZIP_UNCOMPRESSED_MB=100

RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20

JOB_STORAGE_DIR=./data/job_artifacts
JOB_RETENTION_HOURS=24

FREE_DAILY_JOBS=50
PRO_DAILY_JOBS=500
BUSINESS_DAILY_JOBS=5000
FREE_BATCH_ENTRIES=25
PRO_BATCH_ENTRIES=100
BUSINESS_BATCH_ENTRIES=250

ADMIN_EMAILS=admin@example.com
APP_BASE_URL=http://localhost:3000

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_BUSINESS=
